# NATS
NATS_URL=nats://<hub-ip>:4222

# Auth — use one of the following, not both
NATS_CREDS_FILE=/creds/user.creds   # JWT auth (takes priority)
# NATS_USER=<username>              # Basic auth
# NATS_PASSWORD=<password>          # Basic auth

# S3
S3_BUCKET=<your-s3-bucket>

# Restore only
# RESTORE_DATE=2024-01-15-10-30-00
